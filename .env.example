# ── Frontend (set in Netlify → Site settings → Environment variables) ─────────
# Set this to your deployed proxy URL once you have it, e.g.
# VITE_TRAVEL_PROXY_URL=https://onestoptrip-proxy.onrender.com
# Leave blank to hit live APIs directly (works but no retry/cache layer).
VITE_TRAVEL_PROXY_URL=

# ── Proxy server (set in Render/Railway → Environment) ────────────────────────
# Your Netlify site origin, e.g. https://your-site.netlify.app
TRAVEL_PROXY_ALLOWED_ORIGINS=http://localhost:5173
TRAVEL_PROXY_PORT=8787
TRAVEL_PROXY_RATE_LIMIT=180
